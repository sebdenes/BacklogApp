# Cortex Configuration
# Copy to .env and fill in your values

# Port to expose (default: 8000)
PORT=8000

# API key for backlog read/write endpoints (optional — no auth in dev mode)
BACKLOG_API_KEY=

# Bearer token for the /api/backlog/inbox POST webhook (required for webhook to work)
BACKLOG_WEBHOOK_SECRET=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000

# App version (set by CI/CD)
APP_VERSION=dev

# ── Telegram Bot ──
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=
